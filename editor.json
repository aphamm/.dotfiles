{
  // BASICS
  // parse this file (and other editor.json) as JSONC so comments are allowed
  "files.associations": { "editor.json": "jsonc" },
  "workbench.statusBar.visible": false,
  "workbench.startupEditor": "none",
  "editor.minimap.enabled": false,
  "extensions.ignoreRecommendations": true,
  "chat.disableAIFeatures": true,

  // THEMES — auto-switch with OS appearance
  "window.autoDetectColorScheme": true,
  "window.zoomLevel": 0.4,
  "workbench.preferredLightColorTheme": "Ayu Light",
  "workbench.preferredDarkColorTheme": "Ayu Dark",
  "custom-ui-style.font.sansSerif": "Geist Mono",
  "editor.fontFamily": "Geist Mono",

  // SIDEBAR
  "workbench.tree.indent": 20,
  "explorer.compactFolders": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false,

  // EDITOR
  "editor.fontSize": 16,
  "editor.fontLigatures": true,
  "editor.lineHeight": 1.5,
  "editor.multiCursorModifier": "ctrlCmd",
  "editor.cursorStyle": "block",
  // italicize comments
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": "comment",
        "settings": {
          "fontStyle": "italic"
        }
      }
    ]
  },


  // FORMATTER
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "editor.tabSize": 2,
  "editor.detectIndentation": false,
  "files.autoSave": "afterDelay",
  "editor.formatOnSave": true,
  "editor.formatOnType": true,
  "editor.defaultFormatter": "biomejs.biome",
  "[just]": {
    "editor.formatOnSave": false
  },
  "[python]": {
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports": "explicit"
    },
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer"
  },
}
